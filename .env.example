# Clicks Protocol — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Deployer wallet private key (without 0x prefix is also fine)
PRIVATE_KEY=

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
# Get at: https://basescan.org/apis
BASESCAN_API_KEY=

# Protocol treasury address (receives 2% fee)
TREASURY_ADDRESS=

# Set to "true" to fork Base Sepolia in local tests
FORK=false

# Set to "true" to print gas costs in tests
REPORT_GAS=false
